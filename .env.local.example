# Vercel Blob video URLs (set these in Vercel dashboard after running upload-videos script)
NEXT_PUBLIC_HERO_VIDEO_URL=
NEXT_PUBLIC_TOUR_VIDEO_URL=

# Vercel Blob token (needed ONLY for running scripts/upload-videos.mjs locally)
# Get from: Vercel Dashboard → Your Project → Storage → Blob → .env.local
BLOB_READ_WRITE_TOKEN=
